# ============================================================
# QA Agent Platform — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.

# ── Application ──────────────────────────────────────────────
APP_NAME=QA Agent Platform
APP_VERSION=1.0.0
DEBUG=false

# ── OpenAI / LLM ─────────────────────────────────────────────
# Required for real AI analysis. Leave blank to use mock responses.
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://your-custom-llm-endpoint/v1  # Optional: Azure OpenAI or proxy
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# ── Jira MCP ─────────────────────────────────────────────────
# Set USE_MOCK_JIRA=false to connect to a real Jira instance.
USE_MOCK_JIRA=true
JIRA_BASE_URL=https://your-org.atlassian.net/rest/api/3
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_EMAIL=your-email@company.com
JIRA_PROJECT_KEY=PROJ

# ── GitHub MCP ───────────────────────────────────────────────
# Set USE_MOCK_GITHUB=false to connect to a real GitHub repo.
USE_MOCK_GITHUB=true
GITHUB_TOKEN=ghp_your-github-personal-access-token
GITHUB_REPO_OWNER=your-github-org
GITHUB_REPO_NAME=your-main-repo
GITHUB_AUTOMATION_REPO=your-automation-repo  # Used for optional PR creation

# ── Jira Automation Webhook ───────────────────────────────────
# Shared secret for POST /api/v1/webhooks/jira (X-Webhook-Secret header)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JIRA_WEBHOOK_SECRET=your-strong-secret-here

# ── Output Paths (relative to project root) ──────────────────
REPORTS_PATH=outputs/reports
TESTCASES_PATH=outputs/testcases
BDD_PATH=outputs/bdd
